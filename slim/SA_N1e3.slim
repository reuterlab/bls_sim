// define the reproduction function
// probability of being a parent of the next generation is given by fitness
reproduction () {
    females = p1.subsetIndividuals(sex="F");
    males = p1.subsetIndividuals(sex="M");
    moms = sample(females, asInteger(N), replace=T, weights=females.tagF);
    dads = sample(males, asInteger(N), replace=T, weights=males.tagF);
    for (i in seqLen(asInteger(N))){
      p1.addCrossed(moms[i], dads[i]);
    }  
    self.active = 0; // usually the reproduction function is called once per individual. This disables it such that the reproduction function is called once to trigger reproduction of the whole population at once. 
}

// survival is independent of fitness; parents die, offspring live
survival() {
  return (individual.age == 0);
}

///////////////////////////////////////////////////////////////

initialize() {
    // command line params
//    defineConstant("d_folder", "/home/debora/Dropbox/private/projects/uclpostdoc/bls_sim/slimout/SA_N1e2testing");
//    defineConstant("d_repID", 1); //1-10000
//    defineConstant("d_seed", 1); // random number $RANDOM
//    defineConstant("jobid", 1); //job id in cluster $JOB_ID
//    defineConstant("sf",0.1); // grid 0-0.2 by 0.01
//    defineConstant("sm",0.1); // grid 0-0.2 by 0.01
//    defineConstant("h",0.5); //0.5 or 0.25

    setSeed(d_seed); 
    defineConstant("OutputFile", d_folder+"output_sfm"+sf+"-"+sm+"_h"+h+"_r" + d_repID + "_s"+d_seed+"_j"+jobid+ ".SA_N1e3.txt");
    defineConstant("SimEND", 400000);
    defineConstant("SimOUT", c(4000,40000,400000));
    defineConstant("starttime", clock());
    full_genome_len = 10000 - 1; // simulate 10kb sequence
    defineConstant("scaling_factor", 1);
    defineConstant("N", round(1000/scaling_factor)); 	

    // define the simulation type
    initializeSLiMModelType("nonWF");
    initializeSLiMOptions(mutationRuns=1);
    initializeTreeSeq();
    //"A" specifies modeling of an autosome. This is essential to turn on modelling separate sexes on slim (default is hermaphroditic individuals)
    initializeSex("A");
    initializeRecombinationRate(scaling_factor*0.5e-8);
    // sa mutation type: we'll do selection by hand
    initializeMutationRate(0);
    initializeMutationType("m1", 0.5, "f", 0.0);
    // g1 genomic element type: uses msa for all mutations
    initializeGenomicElementType("g1", m1, 1.0);
    // single-locus chromosome
    initializeGenomicElement(g1, 0, full_genome_len);
}
//First cycle: create ancestral pop and empty pops
//NOTE:  reproduction() happens *before* early() in a nonWF model
1 early() {
    sim.addSubpop("p1", asInteger(N));
    sim.subpopulations.individuals.tagF = 1.0; // all individuals start with fitness of 1
    sim.setValue("maxfreq", 0); // variable to store maximum frequency achieved by mutation
}
2: early(){
    sim.subpopulations.individuals.tagF = 1.0; // all individuals start with fitness of 1
}
// add mutation late in this cycle because otherwise I got error "addNewMutation() cannot add mutations to individuals of age > 0 when tree-sequence recording is enabled, to prevent internal inconsistencies."
1 late(){
    g = sim.subpopulations.genomes;
    g[sample(1:(2*N),1)].addNewMutation(m1, 0.0, 4999, originSubpop=1);
    // Start creating output
    writeFile(OutputFile, "sf,sm,h,4000,40000,400000,lost,fixed,maxfreq" , append=F);
    defineGlobal("output", c(sf,sm,h));
    print("STARINTING SA at cycle "+sim.cycle);
    print("sf "+sf);
    print("sm "+sm);
    print("h "+h);     
    alpham = 0.5*(sf*(1-2*h) + sm*(1-2*h));
    s = (sf+sm)/2;
    alphac = s*(1-2*h)+2*sf*sm*h^2;
    pstar = (sf*(1-h)-sm*h) / ((sf+sm)*(1-2*h));
    sa1 = (sm*h) / (1-h+sm*h);
    sa2 = (sm*(1-h)) / (h*(1-sm));
    print("p* "+pstar);
    print("Ne*alpha "+N*alphac);
	 print("conditions for balsel: "+sa1+"<"+sf+"<"+sa2);
	 print("alpha_mullon="+alpham+"; alpha_connallon="+alphac+" pstar="+pstar);
}
// early in each cycle, calculate fitness of individuals
2:400000 early() {
    for (mut in sim.mutations) {
      for (pop in sim.subpopulations) {
//        if(mut.getValue("mb")==0){ // considering mutation is beneficial to females; male beneficial mutations will have everything mirrored here
        for (ind in pop.individuals) {
          num_copies = sum(ind.genomes.containsMutations(mut));
          if (ind.sex == "F") { //females:
              if (num_copies == 1) { //  htz female fitness = 1-sh
                ind.tagF = ind.tagF * (1.0 - sf * h);
              } else if (num_copies == 0) { // hmz female without mutation, fitness = 1-s
                ind.tagF = ind.tagF * (1.0 - sf);
              }  
          } else { //males:
              if (num_copies == 1) { // htz males fitness = 1-sh
                ind.tagF = ind.tagF * (1.0 - sm * h);
              } else if (num_copies == 2) { //hmz males with mutation fitness = 1-s
                ind.tagF = ind.tagF * (1.0 - sm);
              }  
          } // loop males
        } // loop individuals
      sum_fitness = sum(pop.individuals.tagF); 
      fits = pop.individuals.tagF * N / sum_fitness; // relative fitness
      pop.individuals.fitnessScaling = fits;
      } // loop subpopulations
    } // loop mutation
} 

// late in each cycle, check if mutation was fixed or lost, and print out it's frequency
2:400000 late() {
    if(size(sim.mutations)>0){ // if mutation is still there
        for(mut in sim.mutations){
          mut_freq = mean(p1.individuals.genomes.containsMutations(mut));
          if(mut_freq>sim.getValue("maxfreq")){
            sim.setValue("maxfreq", mut_freq);
          }
        } 
        if(mut_freq==1){ // if mutation was fixed
          rest_records = sum(SimOUT-sim.cycle>0); // how manu SimOUT steps have not been output
          newoutput=c(output, rep("1", rest_records)); // write to out file that frequency of mutation is 1 until the end
          defineGlobal("output", newoutput);
          writeFile(OutputFile, paste(c(output, "NA", sim.cycle, sim.getValue("maxfreq")), sep=","), append=T);
          sim.simulationFinished();
          print("time at ENDSIM: " + (clock() - starttime));
          print("ENDSIM Finished with fixed mut at cycle " + sim.cycle);
        }
        else{ // if mutation is segregating
            if(any(sim.cycle == SimOUT)){
                newoutput=output;
                defineGlobal("output", c(newoutput, mut_freq));
            }
            if(sim.cycle==SimEND){
                writeFile(OutputFile, paste(c(output, "NA", "NA", sim.getValue("maxfreq")), sep=","), append=T);
                print("time at ENDSIM: " + (clock() - starttime));
                print("ENDSIM Reached the end of simulation at " +sim.cycle+" with mutation at freq="+mut_freq);
            }
        }
    }
    else{ // if there are zero mutations
        rest_records = sum(SimOUT-sim.cycle>0); // how many steps of SimSTEP cycles are missing to get to the end of the simulation
        newoutput=c(output, rep("0", rest_records)); //fill in output vector with zeroes
        defineGlobal("output", newoutput);
        writeFile(OutputFile, paste(c(output, sim.cycle, "NA", sim.getValue("maxfreq")), sep=","), append=T);
        print("ENDSIM with lost mut after SA at cycle " + sim.cycle);
        sim.simulationFinished(); // finish this simulation
        print("time at ENDSIM: " + (clock() - starttime));
    }
}
400000 late(){
    sim.treeSeqOutput(d_folder + "/output_r" + d_repID +  "_s"+d_seed+ "_j"+jobid+ ".trees");
}

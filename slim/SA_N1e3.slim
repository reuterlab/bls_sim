// define the reproduction function
// probability of being a parent of the next generation is given by fitness (stored in tagF)
reproduction () {
    females = p1.subsetIndividuals(sex="F");
    males = p1.subsetIndividuals(sex="M");
    moms = sample(females, asInteger(N), replace=T, weights=females.tagF);
    dads = sample(males, asInteger(N), replace=T, weights=males.tagF);
    for (i in seqLen(asInteger(N))){
      p1.addCrossed(moms[i], dads[i]);
    }  
    self.active = 0; // usually the reproduction function is called once per individual. This disables it such that the reproduction function is called once to trigger reproduction of the whole population at once. 
}

// survival is independent of fitness; parents die, offspring live
survival() {
  return (individual.age == 0);
}

///////////////////////////////////////////////////////////////

initialize() {
    // command line params
//    defineConstant("d_folder", "/home/debora/Dropbox/private/projects/uclpostdoc/bls_sim/slimout/SA_N1e3/");
//    defineConstant("d_repID", 1); //1-10000
//    defineConstant("d_seed", 1); // random number $RANDOM
//    defineConstant("jobid", 1); //job id in cluster $JOB_ID
//    defineConstant("sf",0.1); // grid 0-0.2 by 0.01
//    defineConstant("sm",0.1); // grid 0-0.2 by 0.01
//    defineConstant("h",0.25); //0.5 or 0.25
//    defineConstant("rand_inv", 1); //randomize invading allele?

    setSeed(d_seed); 
    defineConstant("OutputFile", d_folder+"output_sfm"+sf+"-"+sm+"_h"+h+"_r" + d_repID + "_s"+d_seed+"_j"+jobid+ ".SA_N1e3.txt");
    defineConstant("SimEND", 400000);
    defineConstant("SimOUT", c(4000,40000,400000));
    defineConstant("starttime", clock());
    full_genome_len = 10000 - 1; // simulate 10kb sequence
    defineConstant("scaling_factor", 1);
    defineConstant("N", round(1000/scaling_factor)); 	

    // define the simulation type
    initializeSLiMModelType("nonWF");
    initializeSLiMOptions(mutationRuns=1);
    initializeTreeSeq();
    //"A" specifies modeling of an autosome. This is essential to turn on modelling separate sexes on slim (default is hermaphroditic individuals)
    initializeSex("A");
    initializeRecombinationRate(scaling_factor*0.5e-8);
    // sa mutation type: we'll do selection by hand
    initializeMutationRate(0);
    initializeMutationType("m1", 0.5, "f", 0.0);
    // g1 genomic element type: uses msa for all mutations
    initializeGenomicElementType("g1", m1, 1.0);
    // single-locus chromosome
    initializeGenomicElement(g1, 0, full_genome_len);
}
//First cycle: create pop and add mutation
1 first() {
    sim.addSubpop("p1", asInteger(N));
    sim.subpopulations.individuals.tagF = 1.0; // all individuals start with fitness of 1
    sim.setValue("maxfreq", 0); // variable to store maximum frequency achieved by mutation
    sim.setValue("invading_allele", 0); //variable to store which one is the new mutation (A1 or A2)
    g = sim.subpopulations.genomes;
    // add mutation at one random chromosome (frequency=1/2N)
    g[sample(0:((2*N)-1),1)].addNewMutation(m1, 0.0, 4999, originSubpop=1);
    // POSITIVE SELECTION
    for (mut in sim.mutations){ // start mutation with selection coefficient of -1
    // relative fitness will be calculated below and will be AA=0.5, Aa=0.75, aa=1
        mut.setValue("s", 1);
        mut.setValue("bls", "NA"); // these variables store wheter the mutation is under positive selection (NA) or balancing selection (1)
        sim.setValue("bls", "NA");
	     // calculate fitness under positive selection
	 	  for(pop in sim.subpopulations){
	    	for(ind in pop.individuals){
    			num_copies = sum(ind.genomes.containsMutations(mut));
      		// fitness of the 3 genotypes will be AA=1+0, Aa=1+0.5, aa=1+1
      		// normalized fitness: AA=0.5, Aa=0.75, aa=1
      		ind.tagF = 1.0 + (mut.getValue("s")*num_copies/2);
    	 	}//for ind
    	}//for pop
    }//for mut
    // Start creating output
    writeFile(OutputFile, "sf,sm,h,bls_start,4000,40000,400000,lost,fixed,maxfreq,newmut" , append=F);
    defineGlobal("output", c(sf,sm,h));
    print("sf "+sf);
    print("sm "+sm);
    print("h "+h);     
    alpham = 0.5*(sf*(1-2*h) + sm*(1-2*h));
    s = (sf+sm)/2;
    alphac = s*(1-2*h)+2*sf*sm*h^2;
    pstar = (sf*(1-h)-sm*h) / ((sf+sm)*(1-2*h));
    sa1 = (sm*h) / (1-h+sm*h);
    sa2 = (sm*(1-h)) / (h*(1-sm));
    print("p* "+pstar);
    print("Ne*alpha "+N*alphac);
	 print("conditions for balsel: "+sa1+"<"+sf+"<"+sa2);
	 print("alpha_mullon="+alpham+"; alpha_connallon="+alphac+" pstar="+pstar);
}
//NOTE:  reproduction() and survival() happen *after* first() and *before* late in a nonWF model
// late in each cycle, check if mutation was fixed or lost, and if so finish simulation
// if mutation is still segregating, print out its frequency ever X generations, and recalculate fitness of individuals
1:400000 late() {
    if(size(sim.mutations)>0){ // if mutation is still there
        for(mut in sim.mutations){
          // calculate mutation frequency
          mut_freq = mean(p1.individuals.genomes.containsMutations(mut));
          if(mut_freq>sim.getValue("maxfreq")){
            sim.setValue("maxfreq", mut_freq);
          }
        } 
        if(mut_freq==1){ // if mutation was fixed
          rest_records = sum(SimOUT-sim.cycle>0); // how many checkpoints (SimOUT) are missing to get to the end of the simulation
          newoutput=c(output, rep("1", rest_records)); // write to out file that frequency of mutation is 1 until the end
          defineGlobal("output", newoutput);
          writeFile(OutputFile, paste(c(output, "NA", sim.cycle, sim.getValue("maxfreq"), sim.getValue("invading_allele")), sep=","), append=T);
          sim.simulationFinished();
          print("time at ENDSIM: " + (clock() - starttime));
          print("ENDSIM Finished with fixed mut at cycle " + sim.cycle);
        }
        else{ // if mutation is segregating
          if(any(sim.cycle == SimOUT)){
            newoutput=output;
            defineGlobal("output", c(newoutput, mut_freq));
            //save tree sequence at this timepoint as well
            sim.treeSeqOutput(d_folder+"output_sfm"+sf+"-"+sm+"_h"+h+"_r" + d_repID + "_s"+d_seed+"_j"+jobid+"_c"+sim.cycle+".trees");
          }
          if(sim.cycle==SimEND){ //if this is the last generation we're simulating, write outputs and end simulation
            writeFile(OutputFile, paste(c(output, "NA", "NA", sim.getValue("maxfreq"), sim.getValue("invading_allele")), sep=","), append=T);
            sim.treeSeqOutput(d_folder+"output_sfm"+sf+"-"+sm+"_h"+h+"_r" + d_repID + "_s"+d_seed+"_j"+jobid+"_c"+sim.cycle+".trees");
            print("time at ENDSIM: " + (clock() - starttime));
            print("ENDSIM Reached the end of simulation at " +sim.cycle+" with mutation at freq="+mut_freq);
            sim.simulationFinished(); // finish this simulation
          }
          // recalculate fitness of individuals
	  	    // if the mutation is still under positive selection        
          if(mut.getValue("bls")=="NA"){
        	   for(pop in sim.subpopulations){ 
              for(ind in pop.individuals){
                num_copies = sum(ind.genomes.containsMutations(mut));
                ind.tagF = 1.0 + (mut.getValue("s")*num_copies/2);
              }
            }
            // if frequency is >5%, change selection regime to bls
            if(mut_freq>0.05){
          	  mut.setValue("bls",1);
          	  sim.setValue("bls",1);
          	  newoutput=output;
              defineGlobal("output", c(newoutput, sim.cycle));
              print("STARTING SA at cycle "+sim.cycle);
        	     if (rand_inv){ // if we're randomly deciding which one is the invading allele
                invading_allele = sample(1:2, 1); //randomly sample A1 or A2 as the invading allele
                sim.setValue("invading_allele", invading_allele);
              } //if randomize invading
          	  else { // otherwise, allele A2 is always the invading one
                invading_allele = 2; //randomly sample A1 or A2 as the invading allele
                sim.setValue("invading_allele", invading_allele);          	
		        } //not randomizing
            }
          }
          // if the mutation is under balancing selection
          if (mut.getValue("bls")==1){ 
			   for (mut in sim.mutations) {
              for (pop in sim.subpopulations) {
                for (ind in pop.individuals) {
                  num_copies = sum(ind.genomes.containsMutations(mut));
                  if (sim.getValue("invading_allele") == 2){
             		  if (ind.sex == "F") { //in females:
                      if (num_copies == 2) { //  A2A2 females
                        ind.tagF = 1.0 - sf;
                      } else if (num_copies == 1) { // A1A2 females
                        ind.tagF = 1.0 - sf * h;
                      } else if (num_copies == 0) { // A1A1 females
                        ind.tagF = 1.0;
                      }  
                    } else { //in males:
                      if (num_copies == 2) { // A2A2 males
                        ind.tagF = 1.0;
                      } else if (num_copies == 1) { // A1A2 males
                        ind.tagF = 1.0 - sm * h;
                      } else if (num_copies == 0) { // A1A1 males
                        ind.tagF = 1.0 - sm;
                      }  
                    } // if males
                  } //if 2 is invading
             		if (sim.getValue("invading_allele") == 1){
             		  if (ind.sex == "F") { //in females:
                      if (num_copies == 0) { //  A2A2 females
                        ind.tagF = 1.0 - sf;
                      } else if (num_copies == 1) { // A1A2 females
                        ind.tagF = 1.0 - sf * h;
                      } else if (num_copies == 2) { // A1A1 females
                        ind.tagF = 1.0;
                      }  
                    } else { //in males:
                      if (num_copies == 0) { // A2A2 males
                       ind.tagF = 1.0;
                      } else if (num_copies == 1) { // A1A2 males
                        ind.tagF = 1.0 - sm * h;
                      } else if (num_copies == 2) { // A1A1 males
                        ind.tagF = 1.0 - sm;
                      }  
                    } // if males
                  } //if 1 is invading
                } // loop individuals
              } //for pop
            } //for mut
          } //if bls
        }  //if mut_freq!=1
      } //if size(sim_mutations>0)
      else{ // if there are zero mutations
        rest_records = sum(SimOUT-sim.cycle>0); // how many SimOUT checkpoints are missing to get to the end of the simulation
        newoutput=c(output, rep("0", rest_records)); //fill in output vector with zeroes
        defineGlobal("output", newoutput);
        writeFile(OutputFile, paste(c(output, sim.cycle, "NA", sim.getValue("maxfreq"), sim.getValue("invading_allele")), sep=","), append=T);
        print("ENDSIM with lost mut at cycle " + sim.cycle);
        print("time at ENDSIM: " + (clock() - starttime));
        sim.simulationFinished(); // finish this simulation
      }
}
